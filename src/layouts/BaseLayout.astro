---
import '../styles/global.css';
const { title = 'Carlos Francisco Mendoza Lara', description = 'Data Scientist · Actuarial Science · Mathematical Statistics' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
</head>
<body>

  <!-- NAV -->
  <header class="site-nav">
    <div class="container nav-inner">
      <a href={base} class="nav-logo">cfml</a>
      <nav class="nav-links">
        <a href={`${base}/#projects`}>projects</a>
        <a href={`${base}/#about`}>about</a>
        <a href={`${base}/#contact`}>contact</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <span class="footer-name">Carlos Francisco Mendoza Lara</span>
      <span class="footer-copy">© {new Date().getFullYear()}</span>
    </div>
  </footer>

</body>
</html>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(14,14,14,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .nav-logo {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    letter-spacing: 0.08em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.07em;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 6rem;
    padding: 2rem 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-name {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
  }
</style>

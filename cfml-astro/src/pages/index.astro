---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const skills = [
  'Python', 'R', 'Machine Learning', 'Deep Learning',
  'Signal Processing', 'Statistical Modelling',
  'Actuarial Science', 'R Shiny', 'Pandas', 'scikit-learn',
];
---

<BaseLayout>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow fade-up">Data Scientist · Actuary · Querétaro, MX</p>
        <h1 class="hero-name fade-up">
          Carlos Francisco<br />
          <em>Mendoza Lara</em>
        </h1>
        <p class="hero-tagline fade-up">
          I work at the intersection of mathematical statistics, actuarial science,
          and data — building models that make sense of complex systems.
        </p>
        <div class="hero-cta fade-up">
          <a href="#projects" class="btn btn-primary">View projects</a>
          <a href="#contact"  class="btn btn-ghost">Get in touch</a>
        </div>
      </div>
      <div class="hero-avatar fade-up" aria-hidden="true">CF</div>
    </div>
  </section>

  <!-- ── SKILLS ── -->
  <section class="skills-strip">
    <div class="container">
      <div class="pills-row">
        {skills.map(s => <span class="pill">{s}</span>)}
      </div>
    </div>
  </section>

  <!-- ── PROJECTS ── -->
  <section id="projects" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Selected projects</h2>
        <a href="#projects" class="section-more">all projects</a>
      </div>

      <div class="projects-grid">
        {projects.slice(0,1).map(p => (
          <ProjectCard project={p} featured={true} />
        ))}
        {projects.slice(1).map(p => (
          <ProjectCard project={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section id="about" class="section">
    <div class="container about-grid">
      <div class="about-text">
        <h2 class="section-title" style="margin-bottom:1.25rem;">About</h2>
        <p>
          I'm a data scientist with a background in mathematical statistics and
          actuarial science — a combination that means I care as much about the
          rigour behind a model as its results.
        </p>
        <p>
          My work spans audio classification, signal processing, statistical
          software, and predictive modelling. I enjoy building tools that make
          complex ideas accessible — interactive apps, clear visualisations,
          and well-documented code.
        </p>
        <p>
          Based in Querétaro, Mexico. Currently open to data science roles,
          research collaborations, and interesting problems worth solving.
        </p>
      </div>
      <div class="about-stats">
        <div class="stat-card">
          <span class="stat-num">3+</span>
          <span class="stat-label">Projects published</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">2</span>
          <span class="stat-label">Core disciplines</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">MX</span>
          <span class="stat-label">Querétaro, Mexico</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <section id="contact" class="section">
    <div class="container">
      <div class="contact-box">
        <div class="contact-text">
          <h2>Let's work together</h2>
          <p>Open to collaborations, opportunities, and interesting data problems.</p>
        </div>
        <div class="contact-actions">
          <!-- Update these hrefs with your real links -->
          <a href="https://github.com/FranciscoMendozaLara" target="_blank" rel="noopener" class="social-btn">GH</a>
          <a href="https://linkedin.com/in/"                 target="_blank" rel="noopener" class="social-btn">LI</a>
          <a href="mailto:your@email.com"                                                   class="social-btn">@</a>
          <a href="mailto:your@email.com" class="btn btn-primary">Say hello →</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: 5rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: end;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 1.1rem;
  }
  .hero-name {
    font-size: clamp(40px, 7vw, 62px);
    margin-bottom: 0.5rem;
    color: var(--text);
  }
  .hero-name em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-tagline {
    font-size: 15px;
    color: var(--text-muted);
    font-weight: 300;
    max-width: 460px;
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }
  .hero-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .hero-avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 30px;
    color: var(--text-muted);
    flex-shrink: 0;
    align-self: center;
  }

  /* ── Skills strip ── */
  .skills-strip {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── Sections ── */
  .section { padding: 4rem 0; }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }
  .section-title {
    font-size: 26px;
    color: var(--text);
  }
  .section-more {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .section-more:hover { color: var(--accent); }

  /* ── Projects grid ── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  /* ── About ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 3rem;
    align-items: start;
  }
  .about-text p {
    color: var(--text-muted);
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    margin-bottom: 1.1rem;
  }
  .about-stats {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 34px;
    color: var(--text);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* ── Contact ── */
  .contact-box {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .contact-text h2 {
    font-size: 24px;
    margin-bottom: 6px;
  }
  .contact-text p {
    font-size: 14px;
    color: var(--text-muted);
    font-weight: 300;
  }
  .contact-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .social-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    transition: border-color 0.2s, color 0.2s;
  }
  .social-btn:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .hero-inner    { grid-template-columns: 1fr; }
    .hero-avatar   { display: none; }
    .projects-grid { grid-template-columns: 1fr; }
    .projects-grid .project-card--featured { grid-column: span 1; }
    .about-grid    { grid-template-columns: 1fr; }
    .contact-box   { flex-direction: column; align-items: flex-start; }
  }
</style>
